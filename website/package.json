{
  "name": "ply-visualizer-web",
  "version": "1.0.0",
  "description": "Standalone web version of 3D Point Cloud Visualizer",
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "main": "src/main.ts",
  "scripts": {
    "build": "webpack --config webpack.config.cjs --mode=production",
    "dev": "webpack serve --config webpack.config.cjs --mode=development",
    "start": "webpack serve --config webpack.config.cjs --mode=development --open",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:debug": "playwright test --debug"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/three": "^0.184.0",
    "copy-webpack-plugin": "^14.0.0",
    "ts-loader": "^9.5.7",
    "typescript": "^6.0.3",
    "webpack": "^5.106.2",
    "webpack-cli": "^7.0.2",
    "webpack-dev-server": "^5.2.3"
  },
  "dependencies": {
    "@types/js-yaml": "^4.0.9",
    "js-yaml": "^4.1.1",
    "pako": "^2.1.0",
    "three": "^0.184.0"
  }
}
