{
  "name": "ply-visualizer-engine",
  "version": "1.0.0",
  "description": "Shared visualization engine (parsers, renderer, controls) plus its standalone web host",
  "packageManager": "pnpm@10.32.1",
  "main": "src/main.ts",
  "scripts": {
    "build": "webpack --mode=production",
    "dev": "webpack serve --mode=development",
    "start": "webpack serve --mode=development --open",
    "test": "playwright test",
