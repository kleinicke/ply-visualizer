{
  "name": "ply-visualizer",
  "displayName": "3D Point Cloud and Mesh Visualizer (PLY, ...)",
  "description": "A 3D visualizer for point cloud and mesh files like the PLY format using Three.js. Supports 13+ formats: PLY, XYZ, OBJ, STL, PCD, PTS, OFF, GLTF/GLB and depth to point cloud conversions.",
  "version": "1.5.1",
  "packageManager": "pnpm@10.32.1",
  "publisher": "kleinicke",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/kleinicke/ply-visualizer.git"
  },
  "engines": {
    "vscode": "^1.98.0"
  },
  "categories": [
    "Data Science",
    "Visualization",
    "Other"
  ],
  "keywords": [
    "ply",
    "xyz",
    "obj",
    "stl",
    "pcd",
    "pts",
    "off",
    "gltf",
    "glb",
    "xyzn",
    "xyzrgb",
    "tif",
    "tiff",
    "pfm",
    "npy",
    "npz",
    "png",
    "3d",
    "point cloud",
    "pointcloud",
    "mesh",
    "open3d",
    "depth",
    "disparity",
    "eyedome",
    "viewer",
    "three.js",
    "depth image",
    "depth map",
    "CloudCompare"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "customEditors": [
      {
        "viewType": "plyViewer.plyEditor",
        "displayName": "PLY Pointcloud Visualizer",
        "selector": [
          {
            "filenamePattern": "*.ply"
          },
          {
            "filenamePattern": "*.xyz"
          },
          {
            "filenamePattern": "*.xyzn"
          },
          {
            "filenamePattern": "*.xyzrgb"
          },
          {
            "filenamePattern": "*.obj"
          },
          {
            "filenamePattern": "*.stl"
          },
          {
            "filenamePattern": "*.pcd"
          },
          {
            "filenamePattern": "*.pts"
          },
          {
            "filenamePattern": "*.off"
          },
          {
            "filenamePattern": "*.gltf"
          },
          {
            "filenamePattern": "*.glb"
          }
        ]
      }
    ],
    "commands": [
      {
        "command": "plyViewer.openFile",
        "title": "Open with 3D Visualizer",
        "category": "3D Visualizer"
      },
      {
        "command": "plyViewer.openMultipleFiles",
        "title": "Open Multiple Point Cloud Files",
        "category": "3D Visualizer"
      },
      {
        "command": "plyViewer.playPointCloudSequence",
        "title": "Play Point Cloud Sequence (Wildcard)",
        "category": "3D Visualizer"
      },
      {
        "command": "plyViewer.convertTifToPointCloud",
        "title": "Convert TIFF to Point Cloud",
        "category": "3D Visualizer"
      },
      {
        "command": "plyViewer.loadJsonAsPose",
        "title": "Load JSON as 3D Pose",
        "category": "3D Visualizer"
      },
      {
        "command": "plyViewer.convertDepthToPointCloud",
        "title": "Convert PFM to Point Cloud",
        "category": "3D Visualizer"
      },
      {
        "command": "plyViewer.convertNpyToPointCloud",
        "title": "Convert NPY/NPZ to Point Cloud",
        "category": "3D Visualizer"
      },
      {
        "command": "plyViewer.convertPngToPointCloud",
        "title": "Convert PNG Depth to Point Cloud",
        "category": "3D Visualizer"
      },
      {
        "command": "plyViewer.convertExrToPointCloud",
        "title": "Convert EXR Depth to Point Cloud",
        "category": "3D Visualizer"
      },
      {
        "command": "plyViewer.resetSettings",
        "title": "Reset All Settings",
        "category": "3D Visualizer"
      },
      {
        "command": "plyViewer.selectDataset",
        "title": "Select Dataset Scene",
        "category": "3D Visualizer"
      },
      {
        "command": "plyViewer.clearDatasetCache",
        "title": "Clear Dataset Cache",
        "category": "3D Visualizer"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "plyViewer.openFile",
          "when": "resourceExtname == .ply || resourceExtname == .xyz || resourceExtname == .xyzn || resourceExtname == .xyzrgb || resourceExtname == .txt || resourceExtname == .obj || resourceExtname == .stl || resourceExtname == .pcd || resourceExtname == .pts || resourceExtname == .off || resourceExtname == .gltf || resourceExtname == .glb",
          "group": "navigation"
        },
        {
          "command": "plyViewer.convertTifToPointCloud",
          "when": "resourceExtname == .tif || resourceExtname == .tiff",
          "group": "navigation"
        },
        {
          "command": "plyViewer.convertDepthToPointCloud",
          "when": "resourceExtname == .pfm",
          "group": "navigation"
        },
        {
          "command": "plyViewer.convertNpyToPointCloud",
          "when": "resourceExtname == .npy || resourceExtname == .npz",
          "group": "navigation"
        },
        {
          "command": "plyViewer.loadJsonAsPose",
          "when": "resourceExtname == .json",
          "group": "navigation"
        },
        {
          "command": "plyViewer.convertPngToPointCloud",
          "when": "resourceExtname == .png",
          "group": "navigation"
        }
      ],
      "editor/title/context": [
        {
          "command": "plyViewer.convertTifToPointCloud",
          "when": "resourceExtname == .tif || resourceExtname == .tiff",
          "group": "navigation"
        },
        {
          "command": "plyViewer.convertDepthToPointCloud",
          "when": "resourceExtname == .pfm",
          "group": "navigation"
        },
        {
          "command": "plyViewer.convertNpyToPointCloud",
          "when": "resourceExtname == .npy || resourceExtname == .npz",
          "group": "navigation"
        },
        {
          "command": "plyViewer.convertPngToPointCloud",
          "when": "resourceExtname == .png",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "pnpm run compile",
    "compile": "webpack",
    "build:wasm": "cd wasm/pointcloud-parser && wasm-pack build --target nodejs --release && echo 'exports.memory = wasm.memory;' >> pkg/pointcloud_parser.js",
    "compile:tests": "tsc",
    "compile:all": "pnpm run compile && pnpm run compile:tests",
    "watch": "webpack --watch",
    "pretest": "pnpm run clean && pnpm run compile:all && pnpm run lint",
    "clean": "rm -rf out/",
    "lint": "eslint src --ext ts",
    "test": "node ./out/src/test/runTest.js",
    "test:coverage": "pnpm run pretest && c8 node ./out/src/test/runTest.js",
    "coverage": "pnpm run test:coverage && pnpm run coverage:report",
    "coverage:report": "c8 report && node ./analyze-coverage.mjs",
    "test:ui": "pnpm run compile && cd ui-tests && pnpm exec tsc && cd .. && node ./out/ui-tests/ui-test-runner.js",
    "test:all": "pnpm run test && pnpm run test:ui",
    "test:stl": "node test-stl.js",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "devDependencies": {
    "@types/glob": "^8.0.0",
    "@types/mocha": "^10.0.1",
    "@types/node": "20.17.57",
    "@types/pako": "^2.0.4",
    "@types/three": "^0.185.0",
    "@types/vscode": "1.98.0",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "@vscode/test-electron": "^2.2.0",
    "c8": "^11.0.0",
    "copy-webpack-plugin": "^14.0.0",
    "eslint": "^10.2.1",
    "glob": "^13.0.6",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.6",
    "mocha": "^11.7.5",
    "prettier": "^3.6.2",
    "ts-loader": "^9.5.7",
    "typescript": "^6.0.3",
    "vscode-extension-tester": "^8.17.0",
    "webpack": "^5.106.2",
    "webpack-cli": "^7.0.2",
    "webpack-dev-server": "^5.2.3"
  },
  "dependencies": {
    "@types/js-yaml": "^4.0.9",
    "7zip-min": "^3.0.1",
    "geotiff": "^3.0.5",
    "js-yaml": "^4.1.1",
    "lzma": "^2.3.2",
    "pako": "^2.1.0",
    "three": "^0.185.0"
  },
  "c8": {
    "include": [
      "out/**/*.js"
    ],
    "exclude": [
      "out/test/**",
      "out/src/test/**",
      "out/webview/**",
      "node_modules/**"
    ],
    "reporter": [
      "text",
      "html",
      "lcov"
    ],
    "reports-dir": "coverage",
    "all": true
  },
  "lint-staged": {
    "*.{js,ts,tsx,json,css,md}": [
      "prettier --write"
    ],
    "*.{js,ts,tsx}": [
      "eslint --fix"
    ]
  }
}
